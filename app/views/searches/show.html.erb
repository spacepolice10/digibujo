<div class="search">
  <div class="bullets-timeline-header">
    <div class="bullets-timeline-header-group">
      <%= link_to "Today", bullets_path, class: "button-tertiary", data: { turbo_frame: "_top" } %>
    </div>
    <h2 class="bullets-timeline-header-date">Search</h2>
    <div class="bullets-timeline-header-group">
      <%= link_to triage_path, class: "button-secondary", data: { turbo_frame: "_top" } do %>
        <i class="icon" style="--icon-mask: var(--icon-circle-check)" aria-hidden="true"></i>
        Triage
      <% end %>
    </div>
  </div>

  <%= form_with url: search_path,
        method: :get,
        local: true,
        class: "search--form",
        data: {
          controller: "search",
          search_target: "form"
        } do |form| %>
    <%= form.label :q, "Search bullets", class: "search--label" %>
    <%= form.search_field :q,
          value: @query,
          placeholder: "Search by bullet text or project",
          class: "search--input",
          data: {
            action: "input->search#search",
            search_target: "input"
          },
          autocomplete: "off" %>
  <% end %>

  <turbo-frame id="search_results">
    <%= render "results" %>
  </turbo-frame>
</div>
