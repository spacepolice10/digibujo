<%= tag.div(flash[:alert], style: "color:red") if flash[:alert] %>
<%= tag.div(flash[:notice], style: "color:green") if flash[:notice] %>

<p>We sent a code to <strong><%= @email %></strong></p>

<%= form_with url: session_code_path do |form| %>
  <%= form.text_field :code, required: true, autofocus: true, autocomplete: "one-time-code", inputmode: "text", maxlength: 6, placeholder: "Enter 6-character code", style: "font-family: monospace; text-transform: uppercase; letter-spacing: 4px;" %><br>
  <%= form.submit "Verify code" %>
<% end %>
<br>

<%= link_to "Didn't receive it? Try again", new_session_path %>
