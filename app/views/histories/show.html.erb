<div class="cards-timeline">
  <div class="cards-timeline-header">
    <div class="cards-timeline-header-group">
      <%= link_to "Today", todays_path, class: "button-tertiary" %>
    </div>
    <h2 class="cards-timeline-header-date">History</h2>
    <div class="cards-timeline-header-group">
      <%= link_to search_path, class: "button-secondary", data: { turbo_frame: "_top" } do %>
        <i class="icon" style="--icon-mask: var(--icon-search)" aria-hidden="true"></i>
        Search
      <% end %>
      <%= link_to triage_path, class: "button-secondary", data: { turbo_frame: "_top" } do %>
        <i class="icon" style="--icon-mask: var(--icon-circle-check)" aria-hidden="true"></i>
        Triage
      <% end %>
    </div>
  </div>

  <%= render "cards/paginated_list", cards: @cards, page: @page %>

  <div class="cards-timeline-composer">
    <p class="cards-timeline-note text-sm">You are browsing history. Switch to Today to capture new cards.</p>
  </div>
</div>
