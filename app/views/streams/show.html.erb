<%= turbo_frame_tag "cards_panel" do %>
  <div style="display: flex; align-items: baseline; gap: 1rem;">
    <h1><%= @stream.name %></h1>
    <% unless @stream.default? %>
      <%= button_to "Delete", stream_path(@stream), method: :delete,
            data: { turbo_confirm: "Delete this stream?" } %>
    <% end %>
  </div>

  <%= render "cards/paginated_list" %>
<% end %>
