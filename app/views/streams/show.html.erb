<% content_for(:title) { @stream.name } %>
<div class="bullet-show">
  <nav class="show-navigation">
    <button class="button-secondary" onclick="history.back()">
      <i class="icon" style="--icon-mask: var(--icon-arrow-left)" aria-hidden="true"></i>
      Back
    </button>
    <div class="show-navigation-actions">
      <%= link_to @done_last ? stream_path(@stream) : stream_path(@stream, sort: "done_last"),
            class: "button-secondary #{"button-secondary--active" if @done_last}",
            data: { turbo_frame: "bullets_panel", turbo_action: "advance" },
            title: @done_last ? "Restore default sort" : "Sort done bullets last" do %>
        <i class="icon" style="--icon-mask: var(--icon-circle-check)" aria-hidden="true"></i>
        Done last
        <i class="icon sort-direction-arrow" style="--icon-mask: var(--icon-arrow-up); transform: rotate(<%= @done_last ? "180deg" : "0deg" %>)" aria-hidden="true"></i>
      <% end %>
      <%= link_to edit_stream_path(@stream), class: "button-secondary" do %>
        <i class="icon" style="--icon-mask: var(--icon-pencil)" aria-hidden="true"></i>
        Edit
      <% end %>
      <%= button_to stream_path(@stream), method: :delete, class: "button-secondary button-secondary--danger", form: { data: { turbo_confirm: "Delete this stream?" } } do %>
        <i class="icon" style="--icon-mask: var(--icon-trash)" aria-hidden="true"></i>
        Delete
      <% end %>
    </div>
  </nav>
  <article class="bullet-show-content">
    <header class="bullet-show-header">
      <div class="bullet-show-meta">
        <% if @stream.icon.present? %>
          <i class="icon" style="--icon-mask: var(--icon-<%= @stream.icon %>)<% if @stream.colour.present? %>; color: var(--model-color-<%= @stream.colour %>)<% end %>" aria-hidden="true"></i>
        <% end %>
        <span class="bullet-type">Stream</span>
      </div>
      <h1 class="bullet-show-title"><%= @stream.name %></h1>
      <% unless @stream.empty? %>
        <div class="bullet-tags">
          <% if @stream.bulletable_type.present? %>
            <% @stream.bulletable_type.split(",").map(&:strip).reject(&:blank?).each do |type| %>
              <% stream_icon = type.constantize.icon rescue "menu" %>
              <span class="pill pill--type">
                <i class="icon" style="--icon-mask: var(--icon-<%= stream_icon %>)" aria-hidden="true"></i>
                <%= type.downcase.pluralize %>
              </span>
            <% end %>
          <% end %>
          <% if @stream.date_from.present? || @stream.date_to.present? %>
            <span class="pill pill--date">
              <% if @stream.date_from.present? && @stream.date_to.present? %>
                <%= @stream.date_from %>&ndash;<%= @stream.date_to %>
              <% elsif @stream.date_from.present? %>
                from <%= @stream.date_from %>
              <% else %>
                until <%= @stream.date_to %>
              <% end %>
            </span>
          <% end %>
          <% if @stream.projects.present? %>
            <% @stream.projects.split(",").map(&:strip).reject(&:blank?).each do |project| %>
              <span class="pill"><%= project %></span>
            <% end %>
          <% end %>
        </div>
      <% end %>
    </header>
    <%= render "bullets/paginated_list", bullets: @bullets, page: @page %>
  </article>
</div>
