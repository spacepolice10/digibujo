  <nav class="sidebar-panel" data-controller="nav">
    <div class="sidebar-panel__header">
      <span class="sidebar-panel__title">Index!</span>
      <div class="sidebar-panel__header-actions">
        <%= link_to cards_path(q: ""),
              class: "streams-panel__search-btn",
              aria: { label: "Search" } do %>
          <i class="icon" style="--icon-mask: var(--icon-search)" aria-hidden="true"></i>
        <% end %>
        <%= link_to new_stream_path,
              class: "streams-panel__add-btn",
              aria: { label: "New stream" } do %>+<% end %>
      </div>
    </div>
    <section class="sidebar-panel__section">
      <%= render "streams/card_type" %>
    </section>
    <% if @streams.any? %>
      <section class="sidebar-panel__section">
        <div class="sidebar-panel__section-header">
          <h2 class="sidebar-panel__section-label">Filters</h2>
          <span class="sidebar-panel__section-wavy" aria-hidden="true"></span>
          <%= link_to "View All", streams_path,
                class: "sidebar-panel__section-link",
                "aria-label": "All streams" %>
        </div>
        <ul class="streams-custom-list">
          <% @streams.first(8).each do |stream| %>
            <li>
              <%= link_to stream_path(stream),
                    class: "streams-stream-card",
                    data: { turbo_frame: "_top", turbo_action: "advance" } do %>
                <span class="streams-stream-card__header"<% if stream.colour.present? %> style="color: <%= stream.colour_variable %>"<% end %>>
                  <% if stream.icon.present? %>
                    <span class="streams-stream-icon">
                      <i class="icon" style="--icon-mask: var(--icon-<%= stream.icon %>)" aria-hidden="true"></i>
                    </span>
                  <% end %>
                  <span class="streams-stream-name"><%= stream.name %></span>
                </span>
                <% unless stream.empty? %>
                  <span class="streams-stream-filters">
                    <% if stream.cardable_type.present? %>
                      <% stream.cardable_type.split(",").map(&:strip).reject(&:blank?).each do |type| %>
                        <% stream_icon = type.constantize.icon rescue "menu" %>
                        <span class="pill pill--type">
                          <i class="icon" style="--icon-mask: var(--icon-<%= stream_icon %>)" aria-hidden="true"></i>
                        </span>
                      <% end %>
                    <% end %>
                    <% if stream.tags.present? %>
                      <% stream.tags.split(",").map(&:strip).reject(&:blank?).first(2).each do |tag| %>
                        <span class="pill">#<%= tag %></span>
                      <% end %>
                    <% end %>
                  </span>
                <% end %>
              <% end %>
            </li>
          <% end %>
        </ul>
      </section>
    <% end %>
    <% if @tags.any? %>
      <section class="sidebar-panel__section">
        <div class="sidebar-panel__section-header">
          <h2 class="sidebar-panel__section-label">Tags</h2>
          <span class="sidebar-panel__section-wavy" aria-hidden="true"></span>
          <%= link_to "View All", tags_path,
                class: "sidebar-panel__section-link",
                "aria-label": "All tags",
                data: { turbo_frame: "_top" } %>
        </div>
        <div class="tags-panel-list">
          <% @tags.first(8).each do |tag| %>
            <span class="pill" style="background: <%= tag.colour_bg_variable %>"><%= tag.name %></span>
          <% end %>
        </div>
      </section>
    <% end %>
  </nav>