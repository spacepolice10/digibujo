<turbo-frame id="streams_panel">
  <nav class="sidebar-panel">

    <div class="sidebar-panel__header">
      <span class="sidebar-panel__title">Streams</span>
      <%= link_to new_stream_path,
            class: "streams-panel__add-btn",
            data: { turbo_frame: "modal", action: "dialog#open" },
            aria: { label: "New stream" } do %>+<% end %>
    </div>

    <% defaults, custom = @streams.partition(&:default?) %>

    <section class="sidebar-panel__section">
      <h2 class="sidebar-panel__section-label">Types</h2>
      <ul class="streams-type-list">
        <li>
          <%= link_to cards_path,
                class: "sidebar-panel__item streams-type-item",
                style: "color: var(--model-color-8)",
                data: { turbo_frame: "cards_panel", turbo_action: "advance" } do %>
            <i class="icon" style="--icon-mask: var(--icon-menu)" aria-hidden="true"></i>
            All Cards
          <% end %>
        </li>
        <% defaults.each do |stream| %>
          <li>
            <%= link_to stream_path(stream),
                  class: "sidebar-panel__item streams-type-item",
                  style: stream.colour.present? ? "color: var(--model-color-#{stream.colour})" : nil,
                  data: { turbo_frame: "cards_panel", turbo_action: "advance" } do %>
              <% if stream.icon.present? %>
                <i class="icon" style="--icon-mask: var(--icon-<%= stream.icon %>)" aria-hidden="true"></i>
              <% end %>
              <%= stream.name %>
            <% end %>
          </li>
        <% end %>
      </ul>
    </section>

    <% if custom.any? %>
      <section class="sidebar-panel__section">
        <h2 class="sidebar-panel__section-label">Custom</h2>
        <ul class="streams-custom-list">
          <% custom.each do |stream| %>
            <li>
              <%= link_to stream_path(stream),
                    class: "streams-stream-card",
                    data: { turbo_frame: "cards_panel", turbo_action: "advance" } do %>
                <span class="streams-stream-name"><%= stream.name %></span>
                <% unless stream.empty? %>
                  <div class="streams-stream-chips">
                    <% if stream.tags.present? %>
                      <% stream.tags.split(",").map(&:strip).reject(&:blank?).each do |tag| %>
                        <span class="streams-chip streams-chip--tag">#<%= tag %></span>
                      <% end %>
                    <% end %>
                    <% if stream.cardable_type.present? %>
                      <span class="streams-chip streams-chip--type">
                        <i class="icon" style="--icon-mask: var(--icon-circle-check)" aria-hidden="true"></i>
                        <%= stream.cardable_type.downcase.pluralize %>
                      </span>
                    <% end %>
                    <% if stream.date_from.present? || stream.date_to.present? %>
                      <span class="streams-chip streams-chip--date">
                        <% if stream.date_from.present? && stream.date_to.present? %>
                          <%= stream.date_from %>&ndash;<%= stream.date_to %>
                        <% elsif stream.date_from.present? %>
                          from <%= stream.date_from %>
                        <% else %>
                          until <%= stream.date_to %>
                        <% end %>
                      </span>
                    <% end %>
                  </div>
                <% end %>
              <% end %>
            </li>
          <% end %>
        </ul>
      </section>
    <% end %>

  </nav>
</turbo-frame>
