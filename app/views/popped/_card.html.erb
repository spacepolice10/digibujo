<div id="<%= dom_id(card) %>" class="popped-card">
  <div class="popped-card-content">
    <div class="card-meta">
      <% if card.cardable_type %>
        <span class="card-type"><%= card.name %></span>
      <% end %>
      <span class="pop-date">Popped <%= card.pops_on %></span>
    </div>
    <div class="card-body">
      <%= card.content %>
    </div>
    <% if card.collection.present? %>
      <div class="card-tags">
        <span class="pill" style="background: <%= card.collection.colour_bg_variable %>"><%= card.collection.name %></span>
      </div>
    <% end %>
  </div>
  <div class="popped-card-triage">
    <%= render "cards/triage", card: card %>
  </div>
</div>
