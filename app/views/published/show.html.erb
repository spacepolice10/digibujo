<% content_for(:title) { @card.title } %>
<article class="card-show">
  <header class="card-show-header">
    <div class="card-show-meta">
      <span class="card-type"><%= @card.type_name %></span>
      <% if @card.daylog? && @card.cardable.mood_emoji %>
        <span class="card-mood"><%= @card.cardable.mood_emoji %></span>
      <% end %>
    </div>
    <% if @card.tags.any? %>
      <div class="card-tags">
        <% @card.tags.each do |tag| %>
          <span class="pill" style="background: <%= tag.colour_bg_variable %>"><%= tag.name %></span>
        <% end %>
      </div>
    <% end %>
  </header>
  <div class="card-show-body">
    <%= @card.content %>
  </div>
  <footer class="card-show-footer">
    <time class="card-show-date"><%= @card.created_at.strftime("%-d %b %Y") %></time>
  </footer>
</article>
