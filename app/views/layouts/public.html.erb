<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Digibujo" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1,viewport-fit=cover">
    <meta name="application-name" content="Digibujo">

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@200;400;800&display=swap" rel="stylesheet">

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
  </head>

  <body>
    <div class="public-layout">
      <aside class="public-sidebar">
        <div class="public-branding">
          <img src="/icon.svg" alt="Digibujo" class="public-logo">
          <span class="public-app-name">Digibujo</span>
        </div>
        <div class="public-cta">
          <p>Capture ideas without friction.</p>
          <%= link_to "Create your own", new_session_path, class: "button-primary" %>
        </div>
      </aside>
      <main class="public-content">
        <%= yield %>
      </main>
    </div>
  </body>
</html>
