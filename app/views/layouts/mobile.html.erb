<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Digibujo" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1,viewport-fit=cover">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Digibujo">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@200;400;800&display=swap" rel="stylesheet">

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body data-controller="dialog">
    <main class="main-content main-content--mobile">
      <%= yield %>
    </main>

    <nav class="tab-bar">
      <%= link_to streams_path, class: "tab-bar-item #{'tab-bar-item--active' if controller_name == 'streams'}", aria: { label: "Streams" } do %>
        <i class="icon" style="--icon-mask: var(--icon-list)" aria-hidden="true"></i>
      <% end %>
      <%= link_to cards_path, class: "tab-bar-item #{'tab-bar-item--active' if controller_name == 'cards'}", aria: { label: "Cards" } do %>
        <i class="icon" style="--icon-mask: var(--icon-menu)" aria-hidden="true"></i>
      <% end %>
      <%= link_to upcoming_path, class: "tab-bar-item #{'tab-bar-item--active' if controller_name == 'upcomings'}", aria: { label: "Upcoming" } do %>
        <i class="icon" style="--icon-mask: var(--icon-circle-check)" aria-hidden="true"></i>
      <% end %>
      <%= link_to calendar_path, class: "tab-bar-item #{'tab-bar-item--active' if controller_name == 'calendars'}", aria: { label: "Calendar" } do %>
        <i class="icon" style="--icon-mask: var(--icon-calendar)" aria-hidden="true"></i>
      <% end %>
    </nav>

    <%= link_to new_card_path, class: "fab", aria: { label: "New card" } do %>
      <span class="fab__plus">+</span> Card
    <% end %>

    <dialog data-dialog-target="dialog" data-action="click->dialog#backdropClose turbo:submit-end->dialog#submitEnd">
      <%= turbo_frame_tag "modal" %>
    </dialog>
  </body>
</html>
