<div class="playlists-page">
  <header class="playlists-page__header">
    <a href="<%= playlists_path %>" class="playlists-back-link" data-turbo-frame="_top">
      <span class="icon" style="--icon-mask: var(--icon-arrow-left)" aria-hidden="true"></span>
      All playlists
    </a>
    <div class="playlists-page__title">
      <span class="icon" style="--icon-mask: var(--icon-<%= @playlist.icon %>); color: <%= @playlist.colour_variable %>" aria-hidden="true"></span>
      <h1>Playlist</h1>
      <span class="playlists-page__count"><%= pluralize(@playlist.playlist_bullets.size, "bullet") %></span>
    </div>
  </header>

  <div class="playlists-show__bullets" data-controller="reorder" data-reorder-url-value="<%= playlist_reorder_path(@playlist) %>">
    <% @playlist.playlist_bullets.each do |pc| %>
      <%= render partial: "playlists/playlist_bullet", locals: { playlist: @playlist, pc: pc, reorderable: true } %>
    <% end %>
  </div>

  <% if @playlist.playlist_bullets.empty? %>
    <p class="playlist-popover-empty">No bullets in this playlist yet. Add bullets using the + button in any bullet's menu.</p>
  <% end %>
</div>
