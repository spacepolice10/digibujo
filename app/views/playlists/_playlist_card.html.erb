<div id="<%= dom_id(pc) %>"
     class="playlists-show__bullet"
     <% if local_assigns[:reorderable] %>
       draggable="true"
       data-reorder-id-param="<%= pc.id %>"
       data-action="dragstart->reorder#dragstart dragover->reorder#dragover drop->reorder#drop dragend->reorder#dragend"
     <% end %>>
  <span class="playlist-popover-bullet__drag" aria-hidden="true">⠿</span>
  <%= render partial: "bullets/bullet", locals: { bullet: pc.bullet, dom_prefix: "playlist_#{playlist.id}" } %>
  <%= button_to playlist_bullet_path(playlist, pc), method: :delete,
      class: "playlist-popover-bullet__remove",
      aria: { label: "Remove from playlist" } do %>
    ✕
  <% end %>
</div>
