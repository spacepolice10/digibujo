<turbo-frame id="pinned_panel">
  <% if @pinned_cards.any? %>
    <% stack = @pinned_cards.first(3) %>
    <input type="checkbox" id="pinned-expand" class="pinned-expand-input" autocomplete="off" tabindex="-1">
    <label for="pinned-expand" class="pinned-backdrop" aria-hidden="true"></label>
    <div class="pinned-float">
      <label for="pinned-expand" class="pinned-float-overlay" aria-label="Show pinned cards"></label>
      <div class="pinned-float-stack" style="--card-count: <%= stack.size %>">
        <% stack.each_with_index do |card, i| %>
          <a class="pinned-float-card"
             href="<%= card_path(card) %>"
             data-turbo-frame="_top"
             style="--stack-i: <%= i %>">
            <i class="icon pinned-float-pin" style="--icon-mask: var(--icon-pin)" aria-hidden="true"></i>
            <span class="pinned-float-card-title"><%= card.title %></span>
          </a>
        <% end %>
      </div>
    </div>
  <% end %>
</turbo-frame>
