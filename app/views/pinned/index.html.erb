<turbo-frame id="pinned_panel">
  <% if @pinned_bullets.any? || @playlists.any? %>
    <section class="pinned-dock" aria-label="Dock">
      <div class="pinned-dock__lanes" id="dock_lanes">
        <% if @pinned_bullets.any? %>
          <% stack_bullets = @pinned_bullets.first(3) %>
          <section class="pinned-dock__lane pinned-dock__lane--active">
            <span class="pinned-dock__icon">
              <span class="icon" style="--icon-mask: var(--icon-pin)" aria-hidden="true"></span>
            </span>
            <button class="pinned-stack-trigger"
                    type="button"
                    popovertarget="pinned-bullets-dropdown"
                    aria-label="Show pinned bullets"
                    style="anchor-name: --pinned-stack-trigger">
              <div class="pinned-stack" style="--stack-count: <%= stack_bullets.size %>">
                <% stack_bullets.each_with_index do |bullet, i| %>
                  <div class="pinned-stack-bullet" style="--stack-i: <%= i %>">
                    <span class="pinned-stack-bullet__body">
                      <span class="pinned-stack-bullet__title"><%= bullet.name %></span>
                      <span class="pinned-stack-bullet__meta">
                        <%= bullet.name %>
                        <% if bullet.scheduled_on.present? %>
                          <span class="pinned-stack-bullet__sep" aria-hidden="true">&middot;</span>
                          <time datetime="<%= bullet.scheduled_on.iso8601 %>"><%= bullet.scheduled_on.strftime("%b %-d") %></time>
                        <% end %>
                        <% if bullet.project.present? %>
                          <span class="pinned-stack-bullet__sep" aria-hidden="true">&middot;</span>
                          <%= bullet.project.name %>
                        <% end %>
                      </span>
                    </span>
                  </div>
                <% end %>
              </div>
            </button>
            <div id="pinned-bullets-dropdown"
                 class="dropdown-menu pinned-dropdown-menu"
                 style="position-anchor: --pinned-stack-trigger"
                 popover>
              <section class="pinned-dock-list">
                <div class="pinned-dock-list__header">
                  <div class="pinned-dock__copy">
                    <span class="pinned-dock__eyebrow">Pinned List</span>
                    <span class="pinned-dock__caption"><%= pluralize(@pinned_bullets.count, "bullet") %> pinned right now</span>
                  </div>
                </div>
                <div class="pinned-dock-list__items">
                  <% @pinned_bullets.each do |bullet| %>
                    <%= render partial: "bullets/bullet", locals: { bullet: bullet, dom_prefix: "pinned" } %>
                  <% end %>
                </div>
              </section>
            </div>
          </section>
        <% end %>

        <% @playlists.first(3).each do |playlist| %>
          <%= render partial: "playlists/dock_stack", locals: { playlist: playlist } %>
        <% end %>

        <% if @playlists.size > 3 %>
          <div class="pinned-dock__lane playlist-dock-overflow">
            <a href="<%= playlists_path %>" class="playlist-dock-overflow__link" data-turbo-frame="_top">
              +<%= @playlists.size - 3 %> more
            </a>
          </div>
        <% end %>

        <div class="pinned-dock__lane playlist-dock-create" id="playlists_dock">
          <%= button_to playlists_path, class: "playlist-dock-create__btn", aria: { label: "New playlist" } do %>
            +
          <% end %>
        </div>
      </div>
    </section>
  <% end %>
</turbo-frame>
