<% if bullet.pinned? || bullet.archived? || bullet.scheduled_on.present? || bullet.ends_date.present? || bullet.project.present? || bullet.context_bullet.present? %>
  <div class="bullet-tags">
    <% if bullet.pinned? %>
      <span class="pill pill--status" aria-label="Pinned">
        <span class="icon" style="--icon-mask: var(--icon-pin)"></span>
      </span>
    <% end %>
    <% if bullet.archived? %>
      <span class="pill pill--status" aria-label="Archived">
        <span class="icon" style="--icon-mask: var(--icon-archive)"></span>
      </span>
    <% end %>
    <% if bullet.scheduled_on.present? %>
      <span class="pill pill--date"><%= bullet.scheduled_on.strftime("%-d %b %Y") %><% if bullet.ends_date.present? %> → <%= bullet.ends_date.strftime(bullet.ends_date.to_time.hour.zero? && bullet.ends_date.to_time.min.zero? ? "%-d %b %Y" : "%-d %b %Y %H:%M") %><% end %></span>
    <% elsif bullet.ends_date.present? %>
      <span class="pill pill--date">→ <%= bullet.ends_date.strftime(bullet.ends_date.to_time.hour.zero? && bullet.ends_date.to_time.min.zero? ? "%-d %b %Y" : "%-d %b %Y %H:%M") %></span>
    <% end %>
    <% if bullet.project.present? %>
      <%= link_to project_path(bullet.project),
            class: "pill",
            style: "background: #{bullet.project.colour_bg_variable}",
            data: { turbo_frame: "_top" } do %>
        <i class="icon" style="--icon-mask: var(--icon-tag)" aria-hidden="true"></i>
        <span><%= bullet.project.name %></span>
      <% end %>
    <% end %>
    <% if bullet.context_bullet.present? %>
      <% context_bullet = bullet.context_bullet %>
      <% context_type = context_bullet.bulletable_type.to_s.downcase %>
      <%= link_to bullet_path(context_bullet),
            class: "pill pill--type",
            data: { value: context_type, turbo_frame: "_top" } do %>
        <i class="icon" style="--icon-mask: var(--icon-link)" aria-hidden="true"></i>
        <span><%= bullet.context_name %></span>
      <% end %>
    <% end %>
  </div>
<% end %>
