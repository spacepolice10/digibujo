<div class="future-log">
  <header class="future-log__header">
    <%= link_to calendar_path(year: @year - 1), class: "future-log__year-nav" do %>
      <i class="icon" style="--icon-mask: var(--icon-arrow-left)" aria-hidden="true"></i>
      <%= @year - 1 %>
    <% end %>
    <h1 class="future-log__year"><%= @year %></h1>
    <%= link_to calendar_path(year: @year + 1), class: "future-log__year-nav" do %>
      <%= @year + 1 %>
      <i class="icon icon--flip-h" style="--icon-mask: var(--icon-arrow-left)" aria-hidden="true"></i>
    <% end %>
  </header>

  <div class="future-log__grid">
    <% @months.each do |month| %>
      <div class="future-log__month">
        <h2 class="future-log__month-name"><%= month[:name] %></h2>
        <hr class="future-log__divider">

        <div class="future-log__mini-cal">
          <% CalendarsHelper::LABELS.each do |d| %>
            <span class="future-log__day-label"><%= d %></span>
          <% end %>
          <% calendar_weeks(month[:first_day], month[:days_in_month]).each do |week| %>
            <% week.each do |day| %>
              <% if day %>
                <% day_date  = Date.new(@year, month[:number], day) %>
                <% day_bullets = month[:dates_with_bullets][day_date] %>
                <% types     = day_bullets&.map { |c| c.bulletable_type.downcase }&.uniq&.join(" ") %>
                <span class="future-log__day<%= " future-log__day--today" if day_date == Date.current %>"
                      <%= "data-bullet-types=\"#{types}\"".html_safe if types.present? %>>
                  <%= day %>
                </span>
              <% else %>
                <span class="future-log__day future-log__day--blank"></span>
              <% end %>
            <% end %>
          <% end %>
        </div>

        <% if month[:bullets].any? %>
          <ul class="future-log__events">
            <% month[:bullets].each do |bullet| %>
              <li class="future-log__event future-log__event--<%= bullet.bulletable_type.downcase %>">
                <span class="future-log__event-date"><%= bullet.scheduled_on.day %></span>
                <%= link_to bullet.title, bullet_path(bullet), class: "future-log__event-title", data: { turbo_frame: "_top" } %>
              </li>
            <% end %>
          </ul>
        <% end %>
      </div>
    <% end %>
  </div>
</div>
