<% content_for(:title) { "Daylogs" } %>
<div class="type-index">
  <header class="type-index__header">
    <div class="type-index__title">
      <i class="icon" style="--icon-mask: var(--icon-book); color: var(--model-color-4)" aria-hidden="true"></i>
      <h2>Daylogs</h2>
    </div>
    <div class="type-index__stats">
      <span class="type-index__stat"><strong><%= @total %></strong> total</span>
      <% Daylog::MOOD_EMOJIS.each do |mood, emoji| %>
        <% count = @mood_counts[mood] || 0 %>
        <% if count > 0 %>
          <span class="type-index__stat"><%= emoji %> <strong><%= count %></strong></span>
        <% end %>
      <% end %>
    </div>
  </header>
  <%= render "cards/paginated_list", cards: @cards, page: @page %>
</div>
