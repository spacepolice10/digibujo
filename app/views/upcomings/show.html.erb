<turbo-frame id="upcoming_panel">
  <nav class="calendar-panel sidebar-panel">

    <div class="sidebar-panel__header">
      <span class="sidebar-panel__title">Upcoming</span>
    </div>

    <% if @today_cards.any? %>
      <section class="sidebar-panel__section">
        <h2 class="sidebar-panel__section-label">Today</h2>
        <div class="calendar-section">
          <% @today_cards.each do |card| %>
            <%= render partial: "cards/calendar_card", locals: { card: card } %>
          <% end %>
        </div>
      </section>
    <% end %>

    <% if @upcoming_cards.any? %>
      <section class="sidebar-panel__section">
        <h2 class="sidebar-panel__section-label">Upcoming</h2>
        <div class="calendar-section">
          <% @upcoming_cards.each do |card| %>
            <%= render partial: "cards/calendar_card", locals: { card: card } %>
          <% end %>
        </div>
      </section>
    <% end %>

    <% if @due_cards.any? %>
      <section class="sidebar-panel__section">
        <h2 class="sidebar-panel__section-label sidebar-panel__section-label--alert">Due</h2>
        <div class="calendar-section">
          <% @due_cards.each do |card| %>
            <%= render partial: "cards/calendar_card", locals: { card: card } %>
          <% end %>
        </div>
      </section>
    <% end %>

    <% unless @today_cards.any? || @upcoming_cards.any? || @due_cards.any? %>
      <p class="calendar-empty">Nothing scheduled.</p>
    <% end %>

  </nav>
</turbo-frame>
