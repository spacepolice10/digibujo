<% content_for(:title) { "Events" } %>
<div class="type-index">
  <header class="type-index__header">
    <div class="type-index__title">
      <i class="icon" style="--icon-mask: var(--icon-calendar); color: var(--model-color-6)" aria-hidden="true"></i>
      <h2>Events</h2>
    </div>
    <div class="type-index__stats">
      <span class="type-index__stat type-index__stat--upcoming"><strong><%= @upcoming %></strong> upcoming</span>
      <span class="type-index__stat"><strong><%= @past %></strong> past</span>
    </div>
  </header>
  <%= render "cards/paginated_list", cards: @cards, page: @page %>
</div>
