<% marker_color = case card.cardable_type
                  when "Task" then "var(--model-color-2)"
                  when "Note" then "var(--model-color-5)"
                  when "Event" then "var(--model-color-6)"
                  else "var(--color-fg-subtle)"
                  end %>
<div class="card-action">
  <% if card.completable? %>
    <% if card.done? %>
      <%= button_to card_complete_path(card), method: :delete, class: "completion-toggle done", aria: { label: "Mark undone" } do %>
        &#10003;
      <% end %>
    <% else %>
      <%= button_to card_complete_path(card), method: :post, class: "completion-toggle", aria: { label: "Mark done" } do %>
        &#9675;
      <% end %>
    <% end %>
  <% else %>
    <span class="completion-placeholder" aria-hidden="true" style="color: <%= marker_color %>">
      <span class="completion-marker"><%= card.marker.presence || "•" %></span>
    </span>
  <% end %>
</div>
