<% content_for(:title) { @card.title } %>
<div class="card-show" data-controller="card-inline-edit">
  <nav class="card-show-nav">
    <%= link_to "Back", cards_path, class: "card-show-back" %>
    <div class="card-show-actions">
      <button class="card-show-action card-show-edit-btn" data-action="card-inline-edit#activate">Edit</button>
      <button class="card-show-action card-show-cancel-btn" data-action="card-inline-edit#deactivate" hidden>Cancel</button>
      <%= button_to "Delete", card_path(@card), method: :delete, class: "card-show-action card-show-action--danger", form: { data: { turbo_confirm: "Are you sure?" } } %>
    </div>
  </nav>
  <article class="card-show-content">
    <header class="card-show-header">
      <div class="card-show-meta">
        <% if @card.cardable_type %>
          <span class="card-type"><%= @card.cardable_type %></span>
        <% end %>
        <% if @card.daylog? && @card.cardable.mood_emoji %>
          <span class="card-mood"><%= @card.cardable.mood_emoji %></span>
        <% end %>
        <% if @card.pinned? %>
          <span class="pinned-badge">Pinned</span>
        <% end %>
      </div>
      <% if @card.tags.any? %>
        <div class="card-tags">
          <% @card.tags.each do |tag| %>
            <span class="tag-chip" style="<%= tag.colour_style %>"><%= tag.name %></span>
          <% end %>
        </div>
      <% end %>
    </header>
    <div class="card-show-body"
         data-card-inline-edit-target="readView"
         data-controller="image-zoom"
         data-action="click->image-zoom#zoom click->card-inline-edit#activate">
      <%= @card.content %>
    </div>
    <div data-card-inline-edit-target="editView" hidden>
      <%= render "form", card: @card, autofocus: false %>
    </div>
    <% if @card.popped? %>
      <%= render "cards/triage", card: @card %>
    <% end %>
  </article>
</div>
