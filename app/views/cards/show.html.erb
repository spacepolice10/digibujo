<% content_for(:title) { @card.title } %>
<div class="card-show" data-controller="card-inline-edit">
  <nav class="show-navigation">
    <button class="button-secondary" onclick="history.back()">
      <i class="icon" style="--icon-mask: var(--icon-arrow-left)" aria-hidden="true"></i>
      Back
    </button>
    <div class="show-navigation-actions">
      <button class="button-secondary" data-card-inline-edit-target="editBtn" data-action="card-inline-edit#activate">
        <i class="icon" style="--icon-mask: var(--icon-pencil)" aria-hidden="true"></i>
        Edit
      </button>
      <button class="button-secondary" data-card-inline-edit-target="cancelBtn" data-action="card-inline-edit#deactivate" hidden>
        Cancel
      </button>
      <%= button_to card_path(@card), method: :delete, class: "button-secondary button-secondary--danger", form: { data: { turbo_confirm: "Are you sure?" } } do %>
        <i class="icon" style="--icon-mask: var(--icon-trash)" aria-hidden="true"></i>
        Delete
      <% end %>
      <%= button_to card_pin_path(@card), method: :patch, class: "button-secondary" do %>
        <i class="icon" style="--icon-mask: var(--icon-pin)" aria-hidden="true"></i>
        Pin
      <% end %>
      <%= button_to card_publish_path(@card), method: :patch, class: "button-secondary" do %>
        <i class="icon" style="--icon-mask: var(--icon-link)" aria-hidden="true"></i>
        <%= @card.published? ? "Unpublish" : "Publish" %>
      <% end %>
    </div>
    <% if @card.published? %>
      <div class="published-link">
        <input type="text" value="<%= published_url(@card.public_code) %>" readonly onclick="this.select()">
      </div>
    <% end %>
  </nav>
  <article class="card-show-content">
    <header class="card-show-header">
      <div class="card-show-meta">
        <% if @card.cardable_type %>
          <span class="card-type"><%= @card.type_name %></span>
        <% end %>
        <% if @card.daylog? && @card.cardable.mood_emoji %>
          <span class="card-mood"><%= @card.cardable.mood_emoji %></span>
        <% end %>
        <% if @card.pinned? %>
          <span class="pinned-badge">Pinned</span>
        <% end %>
      </div>
      <% if @card.tags.any? %>
        <div class="card-tags">
          <% @card.tags.each do |tag| %>
            <span class="pill" style="background: <%= tag.colour_bg_variable %>"><%= tag.name %></span>
          <% end %>
        </div>
      <% end %>
    </header>
    <div class="card-show-body"
         data-card-inline-edit-target="readView"
         data-controller="image-zoom"
         data-action="click->image-zoom#zoom click->card-inline-edit#activate">
      <%= @card.content %>
    </div>
    <div data-card-inline-edit-target="editView" hidden>
      <%= render "form", card: @card, autofocus: false %>
    </div>
    <% if @card.popped? %>
      <%= render "cards/triage", card: @card %>
    <% end %>
  </article>
</div>
