<% content_for(:title) { "Card" } %>
<div class="card-show">
  <header class="show-navigation">
    <button class="button-tertiary" onclick="history.back()">
      <i class="icon" style="--icon-mask: var(--icon-arrow-left)" aria-hidden="true"></i>
      Back
    </button>
    <div class="show-navigation-actions">
      <%= link_to edit_card_path(@card), class: "button-secondary", data: { turbo_frame: "_top" } do %>
        <i class="icon" style="--icon-mask: var(--icon-pencil)" aria-hidden="true"></i>
        Edit
      <% end %>
      <%= button_to card_pin_path(@card), method: :patch, class: "button-secondary" do %>
        <i class="icon" style="--icon-mask: var(--icon-pin)" aria-hidden="true"></i>
        <%= @card.pinned? ? "Unpin" : "Pin" %>
      <% end %>
      <%= button_to card_publish_path(@card), method: :patch, class: "button-secondary" do %>
        <i class="icon" style="--icon-mask: var(--icon-link)" aria-hidden="true"></i>
        <%= @card.published? ? "Unpublish" : "Publish" %>
      <% end %>
      <%= button_to card_path(@card), method: :delete, class: "button-secondary button-secondary--danger", form: { data: { turbo_confirm: "Are you sure?" } } do %>
        <i class="icon" style="--icon-mask: var(--icon-trash)" aria-hidden="true"></i>
        Delete
      <% end %>
    </div>
  </header>

  <% if @card.published? %>
    <div class="published-link">
      <input type="text" value="<%= published_url(@card.public_code) %>" readonly onclick="this.select()">
    </div>
  <% end %>

  <article class="card-show-content">
    <div class="card-show-body">
      <%= @card.content %>
    </div>

    <% if @card.popped? %>
      <%= render "cards/triage", card: @card %>
    <% end %>
  </article>
</div>
