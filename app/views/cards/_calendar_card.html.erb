<div id="<%= dom_id(card, :calendar) %>"
     class="calendar-card sidebar-panel__item sidebar-panel__item--<%= card.cardable_type.downcase %><%= " sidebar-panel__item--done" if card.done? %>">
  <% if card.completable? %>
    <% if card.done? %>
      <%= button_to card_complete_path(card),
                    method: :delete,
                    class: "calendar-card-type-toggle calendar-card-type-toggle--task done",
                    aria: { label: "Mark undone" } do %>
        <span class="calendar-card-type-toggle__glyph" aria-hidden="true"></span>
      <% end %>
    <% else %>
      <%= button_to card_complete_path(card),
                    method: :post,
                    class: "calendar-card-type-toggle calendar-card-type-toggle--task",
                    aria: { label: "Mark done" } do %>
        <span class="calendar-card-type-toggle__glyph" aria-hidden="true"></span>
      <% end %>
    <% end %>
  <% else %>
    <i class="icon" style="--icon-mask: <%= card.type_icon_variable %>" aria-hidden="true"></i>
  <% end %>
  <%= link_to card.title, card_path(card),
        data: { turbo_frame: "_top" },
        class: "calendar-card-title" %>
</div>
