<div id="<%= dom_id(card, :calendar) %>"
     class="calendar-card sidebar-panel__item sidebar-panel__item--<%= card.cardable_type.downcase %><%= " sidebar-panel__item--done" if card.done? %>">
  <i class="icon" style="--icon-mask: <%= card.type_icon_variable %>" aria-hidden="true"></i>
  <%= link_to card.title, card_path(card),
        data: { turbo_frame: "_top" },
        class: "calendar-card-title" %>
</div>
