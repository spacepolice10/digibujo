<div id="<%= dom_id(card) %>" class="card<%= " archived" if card.archived? %>"<%= " data-card-type=\"#{card.cardable_type.downcase}\"" unless card.draft? %>>
  <div class="card-action">
    <% if card.completable? %>
      <% if card.done? %>
        <%= button_to card_complete_path(card), method: :delete, class: "completion-toggle done", aria: { label: "Mark undone" } do %>
          &#10003;
        <% end %>
      <% else %>
        <%= button_to card_complete_path(card), method: :post, class: "completion-toggle", aria: { label: "Mark done" } do %>
          &#9675;
        <% end %>
      <% end %>
    <% else %>
      <span class="completion-placeholder"></span>
    <% end %>
  </div>
  <a class="card-body"
     href="<%= card_path(card) %>"
     data-turbo-frame="_top">
    <p class="card-title<%= " done" if card.done? %>">
      <%= card.title %>
    </p>
    <% if card.pinned? || card.archived? || card.date.present? || card.ends_date.present? || card.tags.any? %>
      <div class="card-tags">
        <% if card.pinned? %>
          <span class="tag-chip tag-chip--status" aria-label="Pinned">
            <span class="icon" style="--icon-mask: var(--icon-pin)"></span>
          </span>
        <% end %>
        <% if card.archived? %>
          <span class="tag-chip tag-chip--status" aria-label="Archived">
            <span class="icon" style="--icon-mask: var(--icon-archive)"></span>
          </span>
        <% end %>
        <% if card.date.present? %>
          <span class="tag-chip tag-chip--date"><%= card.date.strftime("%-d %b %Y") %><% if card.ends_date.present? %> → <%= card.ends_date.strftime("%-d %b %Y") %><% end %></span>
        <% elsif card.ends_date.present? %>
          <span class="tag-chip tag-chip--date">→ <%= card.ends_date.strftime("%-d %b %Y") %></span>
        <% end %>
        <% card.tags.each do |tag| %>
          <span class="tag-chip" style="<%= tag.colour_style %>"><%= tag.name %></span>
        <% end %>
      </div>
    <% end %>
  </a>
  <div class="card-menu">
    <button class="card-menu-trigger"
            popovertarget="card-menu-<%= card.id %>"
            style="anchor-name: --card-menu-<%= card.id %>">⋯</button>
    <div id="card-menu-<%= card.id %>"
         class="card-dropdown-menu"
         popover
         style="position-anchor: --card-menu-<%= card.id %>">
      <%= button_to card.pops_on.present? ? "Dismiss" : "Pop",
                    card_pop_path(card),
                    method: :patch,
                    class: "card-dropdown-item" %>
      <%= button_to card.pinned? ? "Unpin" : "Pin",
                    card_pin_path(card),
                    method: :patch,
                    class: "card-dropdown-item" %>
      <%= link_to "Edit",
                   edit_card_path(card),
                   data: { turbo_frame: "_top" },
                   class: "card-dropdown-item" %>
      <%= button_to card.archived? ? "Unarchive" : "Archive",
                    card_archive_path(card),
                    method: :patch,
                    class: "card-dropdown-item" %>
      <%= button_to "Delete",
                    card_path(card),
                    method: :delete,
                    class: "card-dropdown-item card-dropdown-item--danger",
                    form: { data: { turbo_confirm: "Are you sure?" } } %>
    </div>
  </div>
</div>
