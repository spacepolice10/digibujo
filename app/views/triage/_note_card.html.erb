<div id="<%= dom_id(bullet) %>" class="bullet triage-bullet triage-bullet--note <%= "triage-bullet--completed" if bullet.done %>" data-bullet-type="note">
  <div class="bullet-action">
    <span class="completion-placeholder" aria-hidden="true" style="color: var(--model-color-5)">
      <span class="completion-marker"><%= bullet.marker.presence || "-" %></span>
    </span>
  </div>
  <div class="bullet-body">
    <% postponed = bullet.scheduled_on.present? && bullet.scheduled_on > (@selected_date || Date.current) %>
    <%= bullet.content %>
    <% if bullet.project.present? || postponed %>
      <div class="bullet-tags">
        <% if postponed %>
          <span class="pill pill--date pill--migrated">Postponed to <%= bullet.scheduled_on.strftime("%-d %b %Y") %></span>
        <% end %>
        <% if bullet.project.present? %>
          <span class="pill" style="background: <%= bullet.project.colour_bg_variable %>"><%= bullet.project.name %></span>
        <% end %>
      </div>
    <% end %>
  </div>
</div>
