<turbo-frame id="triage_preview">
  <div class="bullets-timeline triage-page">
    <%= render "shared/timeline_header",
               selected_date: @selected_date,
               path_helper: :triage_path,
               context: :triage,
               triage_count: @bullets.size %>

    <div class="triage-description" role="note" aria-label="How to triage bullets">
      <p class="triage-description--copy">
        Do not take everything forward with you. Let&apos;s clean up. Discard anything that is not necessary
        to act on, schedule what should be done, save interesting notes and project tasks to projects,
        and ignore the rest.
      </p>
    </div>

    <div id="triage-bullets">
      <%= render partial: "triage/bullet", collection: @bullets, as: :bullet %>
    </div>

    <% if @bullets.empty? %>
      <p class="triage-empty">No bullets to triage right now.</p>
    <% end %>
  </div>
</turbo-frame>
