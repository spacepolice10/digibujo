<% content_for(:title) { "Archived" } %>
<div class="type-index">
  <header class="type-index__header">
    <div class="type-index__title">
      <i class="icon" style="--icon-mask: var(--icon-archive); color: var(--color-fg-subtle)" aria-hidden="true"></i>
      <h2>Archived</h2>
    </div>
    <div class="type-index__stats">
      <span class="type-index__stat"><strong><%= @total %></strong> total</span>
    </div>
  </header>
  <%= render "bullets/paginated_list", bullets: @bullets, page: @page %>
</div>
