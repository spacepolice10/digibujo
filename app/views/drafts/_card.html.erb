<div id="<%= dom_id(card) %>" class="draft-card">
  <div class="draft-card-paper">
    <div class="draft-card-body">
      <%= card.content %>
    </div>
    <% if card.tags.any? %>
      <div class="card-tags">
        <% card.tags.each do |tag| %>
          <span class="pill" style="background: <%= tag.colour_bg_variable %>"><%= tag.name %></span>
        <% end %>
      </div>
    <% end %>
  </div>

  <aside class="draft-card-toolbar">
    <details class="draft-action-dropdown">
      <summary class="draft-toolbar-btn draft-toolbar-btn--collect" aria-label="Save as note">
        <i class="icon" style="--icon-mask: var(--icon-book)" aria-hidden="true"></i>
      </summary>
      <div class="draft-action-panel">
        <p class="draft-action-panel-title">Save as note</p>
        <%= form_with url: draft_collect_path(card) do |f| %>
          <%= render "cards/fields/tags_picker",
                card: card,
                field_name: "tags",
                frame_id: "collect-tags-#{card.id}" %>
          <%= button_tag type: "submit", class: "draft-toolbar-btn draft-toolbar-btn--collect draft-panel-submit" do %>
            <i class="icon" style="--icon-mask: var(--icon-book)" aria-hidden="true"></i>
            Save as note
          <% end %>
        <% end %>
      </div>
    </details>

    <details class="draft-action-dropdown">
      <summary class="draft-toolbar-btn draft-toolbar-btn--schedule" aria-label="Schedule as task">
        <i class="icon" style="--icon-mask: var(--icon-calendar)" aria-hidden="true"></i>
      </summary>
      <div class="draft-action-panel">
        <p class="draft-action-panel-title">Schedule as task</p>
        <%= form_with url: draft_schedule_path(card) do |f| %>
          <%= f.date_field :date, class: "draft-date-input" %>
          <%= render "cards/fields/tags_picker",
                card: card,
                field_name: "tags",
                frame_id: "schedule-tags-#{card.id}" %>
          <%= button_tag type: "submit", class: "draft-toolbar-btn draft-toolbar-btn--schedule draft-panel-submit" do %>
            <i class="icon" style="--icon-mask: var(--icon-calendar)" aria-hidden="true"></i>
            Schedule
          <% end %>
        <% end %>
      </div>
    </details>

    <div class="draft-toolbar-divider"></div>

    <%= button_to draft_postpone_path(card),
          params: { pops_on: Date.tomorrow },
          class: "draft-toolbar-btn draft-toolbar-btn--postpone",
          aria: { label: "Postpone to tomorrow" } do %>
      <i class="icon" style="--icon-mask: var(--icon-calendar)" aria-hidden="true"></i>
    <% end %>

    <%= button_to draft_postpone_path(card),
          params: { pops_on: 1.week.from_now.to_date },
          class: "draft-toolbar-btn draft-toolbar-btn--postpone",
          aria: { label: "Postpone to next week" } do %>
      <i class="icon icon--flip-h" style="--icon-mask: var(--icon-arrow-up)" aria-hidden="true"></i>
    <% end %>

    <div class="draft-toolbar-divider"></div>

    <%= button_to card_archive_path(card),
          method: :patch,
          class: "draft-toolbar-btn draft-toolbar-btn--archive",
          aria: { label: "Archive" } do %>
      <i class="icon" style="--icon-mask: var(--icon-archive)" aria-hidden="true"></i>
    <% end %>

    <%= button_to draft_remove_path(card),
          class: "draft-toolbar-btn draft-toolbar-btn--remove",
          form: { data: { turbo_confirm: "Are you sure?" } },
          aria: { label: "Delete" } do %>
      <i class="icon" style="--icon-mask: var(--icon-trash)" aria-hidden="true"></i>
    <% end %>
  </aside>
</div>
