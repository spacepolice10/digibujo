<div id="<%= dom_id(card) %>" class="draft-card">
  <div class="draft-card-layout">
    <div class="draft-card-content">
      <div class="draft-card-body">
        <%= card.content %>
      </div>
      <% if card.tags.any? %>
        <div class="card-tags">
          <% card.tags.each do |tag| %>
            <span class="tag-chip" style="<%= tag.colour_style %>"><%= tag.name %></span>
          <% end %>
        </div>
      <% end %>
    </div>

    <aside class="draft-card-actions">
      <details class="draft-action-dropdown">
        <summary class="draft-action draft-action--collect">Save</summary>
        <div class="draft-action-panel">
          <p class="draft-action-panel-title">Save as note</p>
          <%= form_with url: draft_collect_path(card) do |f| %>
            <%= render "cards/fields/tags_picker",
                  card: card,
                  field_name: "tags",
                  frame_id: "collect-tags-#{card.id}" %>
            <%= f.submit "Save", class: "draft-action draft-action--collect" %>
          <% end %>
        </div>
      </details>

      <details class="draft-action-dropdown">
        <summary class="draft-action draft-action--schedule">Schedule</summary>
        <div class="draft-action-panel">
          <p class="draft-action-panel-title">Schedule as task</p>
          <%= form_with url: draft_schedule_path(card) do |f| %>
            <%= f.date_field :date, class: "draft-date-input" %>
            <%= render "cards/fields/tags_picker",
                  card: card,
                  field_name: "tags",
                  frame_id: "schedule-tags-#{card.id}" %>
            <%= f.submit "Schedule", class: "draft-action draft-action--schedule" %>
          <% end %>
        </div>
      </details>

      <div class="draft-action-group--postpone">
        <span class="draft-action-label">Decide later:</span>
        <%= button_to "Tomorrow", draft_postpone_path(card),
              params: { pops_on: Date.tomorrow },
              class: "draft-action draft-action--postpone" %>
        <%= button_to "Next week", draft_postpone_path(card),
              params: { pops_on: 1.week.from_now.to_date },
              class: "draft-action draft-action--postpone" %>
      </div>

      <%= button_to "Archive", card_archive_path(card),
            method: :patch,
            class: "draft-action draft-action--archive" %>

      <%= button_to "Remove", draft_remove_path(card),
            class: "draft-action draft-action--remove",
            form: { data: { turbo_confirm: "Are you sure?" } } %>
    </aside>
  </div>
</div>
