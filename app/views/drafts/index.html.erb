<turbo-frame id="drafts_preview">
  <div class="drafts-triage">
    <div class="drafts-header">
      <%= link_to cards_path, class: "drafts-back-link", data: { turbo_frame: "_top" } do %>
        <i class="icon" style="--icon-mask: var(--icon-arrow-left)" aria-hidden="true"></i>
        Timeline
      <% end %>
      <h1>Review Drafts</h1>
      <p class="drafts-count"><%= @cards.size %> draft<%= @cards.size == 1 ? "" : "s" %> to review</p>
    </div>

    <div id="drafts">
      <% @cards.each do |card| %>
        <%= render "drafts/card", card: card %>
      <% end %>
    </div>

    <% if @cards.empty? %>
      <p class="drafts-empty">No drafts to review. You're all caught up!</p>
    <% end %>
  </div>
</turbo-frame>
